{
  "name": "amt-deltaker-flate",
  "private": true,
  "scripts": {
    "build:pull-request": "turbo build:pull-request",
    "build:demo": "turbo build:demo",
    "build:dev": "turbo build:dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "start": "turbo start",
    "test": "turbo test",
    "test:no-watch": "turbo test:no-watch",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier -w ./**/*",
    "playwright": "turbo playwright",
    "prepare": "husky"
  },
  "devDependencies": {
    "@amt-deltaker-flate/eslint-config": "workspace:*",
    "@amt-deltaker-flate/typescript-config": "workspace:*",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html,yaml,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.28.0",
  "pnpm": {
    "overrides": {
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "picomatch@<4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
