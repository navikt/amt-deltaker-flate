{
  "name": "tiltakskoordinator-flate",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --port 3003",
    "type-check": "tsc --noEmit",
    "build:demo": "vite build --mode demo",
    "build:pull-request": "vite build --mode pull-request",
    "build:dev": "vite build --mode dev --config vite-micro-frontend.config.js",
    "build": "vite build --mode production --config vite-micro-frontend.config.js",
    "test": "vitest",
    "test:no-watch": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "playwright": "playwright test",
    "playwright:debug": "playwright test --debug",
    "playwright:open": "playwright test --ui",
    "playwright:codegen": "playwright codegen playwright.dev",
    "preview": "vite preview"
  },
  "dependencies": {
    "@grafana/faro-react": "catalog:",
    "@grafana/faro-web-sdk": "catalog:",
    "@navikt/aksel-icons": "catalog:",
    "@navikt/ds-css": "catalog:",
    "@navikt/ds-react": "catalog:",
    "@navikt/ds-tailwind": "catalog:",
    "@tanstack/react-query": "catalog:",
    "dayjs": "catalog:",
    "deltaker-flate-common": "workspace:*",
    "msw": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router-dom": "catalog:",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@amt-deltaker-flate/eslint-config": "workspace:*",
    "@amt-deltaker-flate/tailwind-config": "workspace:*",
    "@axe-core/playwright": "catalog:",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-router-dom": "catalog:",
    "@vitejs/plugin-react-swc": "catalog:",
    "jsdom": "catalog:",
    "playwright": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
